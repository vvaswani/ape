# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

############################################
# dependencies (anywhere in repo)
############################################
**/node_modules/
**/.pnp
**/.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

############################################
# testing
############################################
**/coverage/

############################################
# next.js
############################################
**/.next/
**/out/

############################################
# production
############################################
**/build/
**/dist/

############################################
# misc / OS junk
############################################
.DS_Store
Thumbs.db
*.pem

############################################
# debug logs
############################################
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log*
*.log

############################################
# env files (local only)
############################################
.env
.env.*
!.env.example
!.env.sample

############################################
# vercel
############################################
**/.vercel/

############################################
# typescript
############################################
**/*.tsbuildinfo
**/next-env.d.ts

############################################
# generated docs (local)
############################################
docs/reference/api/

############################################
# artifacts (protect local outputs)
############################################
# Local-only subfolders inside artifacts
artifacts/**/local/
artifacts/**/tmp/
artifacts/**/temp/
artifacts/**/output/
artifacts/**/generated/
artifacts/**/downloads/

# Common local data/export file types that often land in artifacts
artifacts/**/*.csv
artifacts/**/*.xlsx
artifacts/**/*.xls
artifacts/**/*.parquet
artifacts/**/*.jsonl
artifacts/**/*.ndjson
artifacts/**/*.zip
artifacts/**/*.gz
artifacts/**/*.7z
artifacts/**/*.pdf

# Allow curated, intentionally committed content
!artifacts/**/examples/**
!artifacts/**/templates/**
!artifacts/**/README.md
!artifacts/**/.keep

# Local-only Codex/LLM handover notes (do not commit)
artifacts/.codex/

############################################
# IDE local MCP config
############################################
.vscode/mcp.json
